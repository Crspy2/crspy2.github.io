---
import Base from "../layouts/Base.astro";
import SectionMarker from "../components/SectionMarker.astro";
---
<Base title="404 — crspy.me" description="Page not found.">
  <section id="not-found" class="not-found" aria-labelledby="not-found-title">
    <SectionMarker index="404" title="NOT_FOUND" />

    <div class="not-found-inner">
      <p class="eyebrow" data-rise>
        <span class="prompt">$</span> cat ~/requested-page
        <span class="error">→ no such file</span>
      </p>

      <h1 id="not-found-title" class="title" data-rise>
        This page <span class="accent">doesn&rsquo;t exist</span>.
      </h1>

      <p class="blurb" data-rise>
        The URL you tried isn&rsquo;t a thing on this site &mdash; mistyped,
        moved, or it never existed. Head back to the index and try again.
      </p>

      <a href="/" class="back-link" data-rise>
        <span class="arrow" aria-hidden="true">↩</span>
        <span>back to home</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .not-found {
    scroll-margin-top: 60px;
    min-height: calc(100svh - 60px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 96px;
  }

  .not-found-inner {
    max-width: 760px;
    margin: 56px auto 0;
    padding: 0 32px;
    width: 100%;
  }

  @media (max-width: 640px) {
    .not-found-inner { padding: 0 20px; }
  }

  .eyebrow {
    margin: 0 0 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-faint);
    letter-spacing: 0.06em;
  }
  .eyebrow .prompt { color: var(--color-accent); margin-right: 4px; }
  .eyebrow .error { color: var(--color-dim); margin-left: 8px; }

  .title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(36px, 6vw, 56px);
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }
  .title .accent {
    color: var(--color-accent);
    border-bottom: 1px dashed var(--color-accent);
    padding-bottom: 1px;
  }

  .blurb {
    margin: 28px 0 36px;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 56ch;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--color-border-strong);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .back-link:hover {
    color: var(--color-foreground);
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .back-link .arrow { color: var(--color-accent); }
</style>
