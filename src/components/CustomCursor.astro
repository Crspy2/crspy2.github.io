---
---
<div class="custom-cursor-dot" aria-hidden="true"></div>
<div class="custom-cursor-ring" aria-hidden="true">
	<span class="custom-cursor-label">
		Click Me
		<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M5 11l6-6m0 0H5.5m5.5 0v5.5"/>
		</svg>
	</span>
</div>

<style is:global>
	.custom-cursor-dot,
	.custom-cursor-ring {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		z-index: 9999;
		will-change: transform;
	}
	.custom-cursor-dot {
		width: 8px;
		height: 8px;
		border-radius: 9999px;
		background: black;
	}
	.custom-cursor-ring {
		width: 36px;
		height: 36px;
		border-radius: 9999px;
		border: 1px solid black;
		background: transparent;
		display: flex;
		align-items: center;
		justify-content: center;
		transition:
			width 0.2s ease,
			height 0.2s ease,
			background-color 0.2s ease,
			border-color 0.2s ease,
			padding 0.2s ease,
			color 0.2s ease;
	}
	.custom-cursor-ring.text-hover {
		width: 56px;
		height: 56px;
		border-color: transparent;
	}
	.custom-cursor-ring.link-hover {
		width: auto;
		height: 32px;
		padding: 0 14px;
		border-color: transparent;
		background-color: black;
		color: white;
		font-size: 11px;
		font-weight: 500;
		white-space: nowrap;
	}
	.custom-cursor-label {
		display: none;
		align-items: center;
		gap: 4px;
	}
	.custom-cursor-ring.link-hover .custom-cursor-label {
		display: flex;
	}

	@media (pointer: fine) {
		html.cursor-active,
		html.cursor-active * {
			cursor: none !important;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.custom-cursor-dot,
		.custom-cursor-ring {
			display: none !important;
		}
	}
</style>

<script>
	import { gsap } from "gsap";

	const dot = document.querySelector<HTMLElement>(".custom-cursor-dot");
	const ring = document.querySelector<HTMLElement>(".custom-cursor-ring");

	if (dot && ring && matchMedia("(pointer: fine)").matches) {
		document.documentElement.classList.add("cursor-active");

		gsap.set([dot, ring], { xPercent: -50, yPercent: -50, x: -9999, y: -9999 });

		const dotX = gsap.quickTo(dot, "x", { duration: 0.05, ease: "power3" });
		const dotY = gsap.quickTo(dot, "y", { duration: 0.05, ease: "power3" });
		const ringX = gsap.quickTo(ring, "x", { duration: 0.25, ease: "power3" });
		const ringY = gsap.quickTo(ring, "y", { duration: 0.25, ease: "power3" });

		document.addEventListener("mousemove", (e) => {
			dotX(e.clientX);
			dotY(e.clientY);
			ringX(e.clientX);
			ringY(e.clientY);
		});

		const findSectionBar = (el: Element): HTMLElement | null => {
			const section = el.closest("[data-page]");
			const bar = section?.querySelector(":scope > .sticky");
			return bar instanceof HTMLElement ? bar : null;
		};

		for (const el of document.querySelectorAll<HTMLElement>(".font-fraunces")) {
			el.addEventListener("mouseenter", () => {
				if (el.closest("a")) return;
				const bar = findSectionBar(el);
				ring.style.backgroundColor = bar ? getComputedStyle(bar).backgroundColor : "";
				ring.classList.add("text-hover");
			});
			el.addEventListener("mouseleave", () => {
				ring.classList.remove("text-hover");
				ring.style.backgroundColor = "";
			});
		}

		for (const link of document.querySelectorAll<HTMLAnchorElement>("a")) {
			link.addEventListener("mouseenter", () => {
				ring.classList.add("link-hover");
			});
			link.addEventListener("mouseleave", () => {
				ring.classList.remove("link-hover");
			});
		}
	}
</script>
