---
import Base from "../layouts/Base.astro"
import SectionMarker from "../components/SectionMarker.astro"
---

<Base title="Not Found - crspy.me" description="Page not found.">
  <section id="not-found" class="not-found" aria-labelledby="not-found-title">
    <SectionMarker index="404" title="NOT_FOUND" />

    <div class="not-found-inner" data-error-variant="default">
      <p class="eyebrow" data-reveal>
        <span class="prompt">$</span> cat <span data-not-found-path>~/</span>
        <span class="error">→ no such file</span>
      </p>

      <h1 id="not-found-title" class="title" data-reveal>
        This page <span class="accent">doesn&rsquo;t exist</span>.
      </h1>

      <p class="blurb" data-reveal>
        The URL you tried isn&rsquo;t a thing on this site. It was either mistyped, moved, or never
        existed in the first place. Head back to &quot;/&quot; and try again.
      </p>

      <a href="/" class="back-link" data-reveal>
        <span class="arrow" aria-hidden="true">↩</span>
        <span>back to home</span>
      </a>
    </div>

    <div class="not-found-inner not-found-blog" data-error-variant="blog" hidden>
      <p class="eyebrow" data-reveal>
        <span class="prompt">$</span> wget <span data-not-found-path>~/</span>
        <span class="error">→ post not found</span>
      </p>

      <h1 class="title" data-reveal>
        This post <span class="accent">doesn&rsquo;t exist</span>.
      </h1>

      <p class="blurb" data-reveal>
        The post you tried isn&rsquo;t here. It was renamed, unpublished, or never existed in the
        first place. The archive has the ones that do.
      </p>

      <a href="/blog/" class="back-link" data-reveal>
        <span class="arrow" aria-hidden="true">↩</span>
        <span>back to archive</span>
      </a>
    </div>
  </section>
</Base>

<script is:inline>
  ;(function () {
    var path = window.location.pathname || "/"

    var pathEls = document.querySelectorAll("[data-not-found-path]")
    for (var i = 0; i < pathEls.length; i++) {
      pathEls[i].textContent = "~" + path
    }

    if (path.indexOf("/blog/") === 0) {
      var def = document.querySelector('[data-error-variant="default"]')
      var blog = document.querySelector('[data-error-variant="blog"]')
      if (def) def.setAttribute("hidden", "")
      if (blog) blog.removeAttribute("hidden")
      document.title = "Post Not Found · crspy.me"
    }
  })()
</script>

<style>
  .not-found {
    scroll-margin-top: 60px;
    min-height: calc(100svh - 60px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 96px;
  }

  .not-found-inner {
    max-width: 760px;
    margin: 56px auto 0;
    padding: 0 32px;
    width: 100%;
  }

  @media (max-width: 640px) {
    .not-found-inner {
      padding: 0 20px;
    }
  }

  [hidden] {
    display: none !important;
  }

  .eyebrow {
    margin: 0 0 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-faint);
    letter-spacing: 0.06em;
  }
  .eyebrow .error {
    color: var(--color-dim);
    margin-left: 8px;
  }

  .title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(36px, 6vw, 56px);
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }

  .blurb {
    margin: 28px 0 36px;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 56ch;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--color-border-strong);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .back-link:hover {
    color: var(--color-foreground);
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .back-link .arrow {
    color: var(--color-accent);
  }

  .not-found-blog {
    --color-accent: var(--color-blog);
  }
</style>
