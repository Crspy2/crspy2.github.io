---
const year = new Date().getFullYear();
---
<footer class="site-footer" data-rise>
  <div class="footer-inner">
    <span class="footer-marker">// END_OF_FILE</span>
    <span class="footer-copy">&copy; {year} crspy</span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 24px 32px 32px;
    border-top: 1px solid var(--color-border);
    margin-top: 24px;
  }

  @media (max-width: 640px) {
    .site-footer { padding: 20px 20px 28px; }
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-dim);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
</style>
