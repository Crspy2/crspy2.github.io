---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const linkType = project.linkType ?? "live";
const isBlog = linkType === "blog";
---
<a
  class={`project-row project-row-${linkType}`}
  href={project.url}
  {...(isBlog ? {} : { target: "_blank", rel: "noopener noreferrer" })}
  data-project-row
  data-rise
>
  <span class="project-year">{project.year}</span>

  <div class="project-body">
    <h3 class="project-name">
      {project.name}
      <span class="project-tagline">{project.tagline}</span>
    </h3>
    <p class="project-tools">
      {project.tools.map((tool, i) => (
        <>
          {i > 0 && <span class="dot" aria-hidden="true">·</span>}
          <span>{tool}</span>
        </>
      ))}
    </p>
  </div>

  {isBlog ? (
    <span class="project-link-indicator project-blog" data-project-live>
      <span class="project-blog-arrow">→</span>
      <span class="project-blog-label">blog</span>
    </span>
  ) : (
    <span class="project-link-indicator project-live" data-project-live>
      <span class="project-live-arrow">↗</span>
      <span class="project-live-label">live</span>
    </span>
  )}
</a>

<style>
  .project-row {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 24px;
    align-items: baseline;
    padding: 22px 12px;
    border-bottom: 1px solid var(--color-border);
    border-left: 2px solid transparent;
    margin-left: -14px;
    position: relative;
    transition:
      border-color 0.18s ease,
      background 0.18s ease;
  }

  /* Default (live) hover uses the accent green */
  .project-row-live:hover {
    border-left-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-background));
  }

  /* Blog hover uses the blog blue */
  .project-row-blog:hover {
    border-left-color: var(--color-blog);
    background: color-mix(in srgb, var(--color-blog) 5%, var(--color-background));
  }

  @media (max-width: 640px) {
    .project-row {
      grid-template-columns: 48px 1fr auto;
      gap: 14px;
      padding: 18px 10px;
    }
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-dim);
    padding-top: 2px;
  }

  .project-name {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(17px, 2vw, 19px);
    font-weight: 500;
    color: var(--color-foreground);
  }

  .project-tagline {
    color: var(--color-faint);
    font-weight: 400;
    font-size: 0.82em;
    margin-left: 6px;
  }

  @media (max-width: 540px) {
    .project-tagline {
      display: block;
      margin-left: 0;
      margin-top: 2px;
    }
  }

  .project-tools {
    margin: 6px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 0 6px;
    line-height: 1.6;
  }

  .project-tools .dot { color: var(--color-dim); }

  /* Right-side link indicator (shared base) */
  .project-link-indicator {
    font-family: var(--font-mono);
    font-size: 11px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    transition: opacity 0.18s ease;
  }

  .project-live { color: var(--color-accent); }
  .project-live-arrow { font-size: 13px; }

  .project-blog { color: var(--color-blog); }
  .project-blog-arrow { font-size: 13px; }
</style>
