---
import SectionBar from "../SectionBar.astro";
import ProjectCard from "../ProjectCard.astro";

const projects = [
	{
		name: "AlteraSMS",
		description: "Description pending — replace with what AlteraSMS does, your role, and the key features.",
		projectUrl: "https://alterasms.io/",
		tools: ["TypeScript", "NextJS", "Stripe"],
	},
	{
		name: "bio.crspy.me",
		description: "This portfolio. Astro + TailwindCSS with GSAP-driven scroll-routing, and a Lanyard-powered live Discord card.",
		projectUrl: "https://bio.crspy.me/",
		tools: ["Astro", "TypeScript", "TailwindCSS"],
	},
	{
		name: "AI Support Agent",
