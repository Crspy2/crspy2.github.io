---
import { Font } from "astro:assets";
import "../styles/global.css";
import Background from "../components/Background.astro";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "crspy.me",
  description = "$ whoami → Crspy. Fullstack web dev writing TypeScript, Go, and Rust out of California.",
} = Astro.props;

const SITE_URL = "https://crspy.me";
const OG_IMAGE = `${SITE_URL}/og-image.png`;
const OG_IMAGE_WIDTH = 1731;
const OG_IMAGE_HEIGHT = 909;
const OG_IMAGE_ALT = "Crspy. Fullstack web developer. Dark terminal-flavored portfolio.";
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    <title>{title}</title>

    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="crspy.me" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:secure_url" content={OG_IMAGE} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:alt" content={OG_IMAGE_ALT} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content={OG_IMAGE_ALT} />

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-jetbrains" preload />

    <noscript>
      <style>
        [data-rise] { clip-path: none !important; }
        [data-section-marker] [data-marker-line] { transform: scaleX(1) !important; }
      </style>
    </noscript>
  </head>
  <body>
    <Background />
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  main {
    position: relative;
    z-index: 1;
  }
</style>

<script>
  import { initSectionMarkers } from "../scripts/section-markers";
  import { initReveal } from "../scripts/reveal";
  import { initScramble } from "../scripts/scramble";
  import { initProjectHover } from "../scripts/project-hover";
  import { installErrorHandler } from "../scripts/error-handler";

  installErrorHandler();

  function init() {
    initSectionMarkers();
    initReveal();
    initScramble();
    initProjectHover();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
