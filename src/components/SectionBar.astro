---
interface Props {
	title: string;
	class?: string;
}

const { title, class: className } = Astro.props;
const colorName = className?.match(/(?:^|\s)bg-([\w-]+)/)?.[1];
---
<div
	class:list={[
		"sticky top-0 z-40 flex justify-between items-center text-2xl md:text-3xl lg:text-5xl h-12 md:h-14 lg:h-18 w-full px-6 md:px-12 lg:px-20",
		className,
	]}
	style={colorName ? `--section-color: var(--color-${colorName});` : undefined}
>
	<span class="font-light font-inter">{title}</span>
	<slot name="right" />
</div>
