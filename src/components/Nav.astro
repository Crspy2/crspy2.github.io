---
const links = [
  { href: "/#about", label: "about" },
  { href: "/#projects", label: "projects" },
  { href: "/blog/", label: "blog" },
  { href: "/#contact", label: "contact" },
];
---
<nav class="site-nav" aria-label="primary" data-reveal data-nav>
  <a href="/" class="brand" aria-label="home">
    <span class="online-dot" aria-hidden="true"></span>
    <span class="brand-name">crspy</span><span class="brand-tld">.me</span>
  </a>
  <ul class="nav-links">
    {links.map(({ href, label }) => (
      <li><a href={href} data-nav-link>{label}</a></li>
    ))}
  </ul>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 32px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-background) 75%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  @media (max-width: 640px) {
    .site-nav { padding: 14px 20px; font-size: 11px; }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-foreground);
  }

  .brand-name { font-weight: 500; }
  .brand-tld { color: var(--color-dim); }

  .online-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
    animation: online-pulse 2.4s ease-in-out infinite;
  }

  @keyframes online-pulse {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .nav-links { gap: 16px; }
  }

  .nav-links a {
    transition: color 0.18s ease;
  }
  .nav-links a:hover {
    color: var(--color-foreground);
  }
</style>
