---
import Base from "../layouts/Base.astro";
import SectionMarker from "../components/SectionMarker.astro";
---
<Base title="Error - crspy.me" description="Something went sideways.">
  <section id="error" class="error-page" aria-labelledby="error-title">
    <SectionMarker index="500" title="EXCEPTION" />

    <div class="error-inner">
      <p class="eyebrow" data-rise>
        <span class="prompt">$</span>
        <span class="throw-keyword">throw</span>
        <span data-error-msg>new Error()</span>
      </p>

      <h1 id="error-title" class="title" data-rise>
        Something went <span class="accent">sideways</span>.
      </h1>

      <p class="blurb" data-rise>
        An unexpected error stopped the page from rendering correctly. The
        site bailed out instead of leaving you with something half-broken.
        Try reloading, or head back to "/".
      </p>

      <div class="actions" data-rise>
        <button type="button" class="action-btn" data-error-reload>
          <span class="arrow" aria-hidden="true">↻</span>
          <span>reload</span>
        </button>
        <a href="/" class="action-btn">
          <span class="arrow" aria-hidden="true">↩</span>
          <span>back to home</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .error-page {
    scroll-margin-top: 60px;
    min-height: calc(100svh - 60px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 96px;
  }

  .error-inner {
    max-width: 760px;
    margin: 56px auto 0;
    padding: 0 32px;
    width: 100%;
  }

  @media (max-width: 640px) {
    .error-inner { padding: 0 20px; }
  }

  .eyebrow {
    margin: 0 0 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-faint);
    letter-spacing: 0.06em;
    word-break: break-word;
  }
  .eyebrow .throw-keyword { color: #ff7b72; margin-right: 6px; }

  .title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(36px, 6vw, 56px);
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }

  .blurb {
    margin: 28px 0 36px;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 56ch;
  }

  .actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--color-border-strong);
    border-radius: 4px;
    background: transparent;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .action-btn:hover {
    color: var(--color-foreground);
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .action-btn .arrow { color: var(--color-accent); }
</style>

<script is:inline>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var msg = params.get("msg");
    var slot = document.querySelector("[data-error-msg]");
    if (slot && msg) {
      slot.textContent = "new Error(" + JSON.stringify(msg) + ")";
    }
    var btn = document.querySelector("[data-error-reload]");
    if (btn) btn.addEventListener("click", function () { location.reload(); });
  })();
</script>
