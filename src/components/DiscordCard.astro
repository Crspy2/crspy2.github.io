---
const DISCORD_USER_ID = import.meta.env.DISCORD_USER_ID || "1323519785694265356";

let displayName = 'Crspy';
let username = 'crs_py';
let avatarUrl = `https://cdn.discordapp.com/avatars/${DISCORD_USER_ID}/08d0274d95b7bb20d32d5b71ec009194.webp?size=128`;
let status: 'online' | 'idle' | 'dnd' | 'offline' = 'offline';
let badges: { id: string; description: string; icon: string; link: string }[] = [];
let bannerUrl: string | null = null;
let avatarDecorationUrl: string | null = null;

try {
	const lanyardRes = await fetch(`https://api.lanyard.rest/v1/users/${DISCORD_USER_ID}`);
	if (lanyardRes.ok) {
		const json = await lanyardRes.json();
		const data = json.data;
		if (data) {
			displayName = data.discord_user.global_name || data.discord_user.username;
			username = data.discord_user.username;
			status = data.discord_status || 'offline';
			const avatarHash = data.discord_user.avatar;
			if (avatarHash) {
				avatarUrl = `https://cdn.discordapp.com/avatars/${data.discord_user.id}/${avatarHash}.webp?size=128`;
			}
			const bannerHash = data.discord_user.banner;
			if (bannerHash) {
				const ext = bannerHash.startsWith('a_') ? 'gif' : 'png';
				bannerUrl = `https://cdn.discordapp.com/banners/${data.discord_user.id}/${bannerHash}.${ext}?size=600`;
			}
			const decoAsset = data.discord_user.avatar_decoration_data?.asset;
			if (decoAsset) {
				avatarDecorationUrl = `https://cdn.discordapp.com/avatar-decoration-presets/${decoAsset}.png`;
			}
		}
	}

	const profileRes = await fetch(`https://dcdn.dstn.to/profile/${DISCORD_USER_ID}`);
	if (profileRes.ok) {
		const profile = await profileRes.json();
		if (profile.badges) badges = profile.badges;
		if (!bannerUrl && profile.user?.banner) {
			const bannerHash = profile.user.banner;
			const ext = bannerHash.startsWith('a_') ? 'gif' : 'png';
			bannerUrl = `https://cdn.discordapp.com/banners/${DISCORD_USER_ID}/${bannerHash}.${ext}?size=600`;
		}
		if (!avatarDecorationUrl && profile.user?.avatar_decoration_data?.asset) {
			const decoAsset = profile.user.avatar_decoration_data.asset;
			avatarDecorationUrl = `https://cdn.discordapp.com/avatar-decoration-presets/${decoAsset}.png`;
		}
	}
} catch {
}

const statusColors: Record<string, string> = {
	online: 'bg-[#23a55a]',
	idle: 'bg-[#f0b232]',
	dnd: 'bg-[#f23f43]',
	offline: 'bg-[#80848e]',
};
const statusColor = statusColors[status] || statusColors.offline;
---
<a
	href={`https://discord.com/users/${DISCORD_USER_ID}`}
	target="_blank"
	rel="noopener noreferrer"
	class="block bg-white hover:bg-neutral-100 transition-colors rounded-lg overflow-hidden w-full border border-neutral-200 select-none"
>
	{bannerUrl ? (
		<div class="h-[60px] w-full overflow-hidden">
			<img src={bannerUrl} alt="" class="w-full h-full object-cover" draggable="false" />
		</div>
	) : (
		<div class="h-[60px] w-full bg-[#5865f2]"></div>
	)}

	<div class="px-4 pb-3">
		<div class="relative w-[72px] h-[72px] -mt-[36px] mb-2">
			<div class="w-[72px] h-[72px] rounded-full border-[4px] border-white overflow-hidden">
				<img src={avatarUrl} alt="Avatar" draggable="false" loading="lazy" decoding="async" class="w-full h-full rounded-full" />
			</div>
			{avatarDecorationUrl && (
				<img
					src={avatarDecorationUrl}
					alt=""
					draggable="false"
					class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[84px] h-auto pointer-events-none"
				/>
			)}
			<span class="absolute bottom-0 right-0">
				<span class={`block w-[20px] h-[20px] rounded-full border-[3px] border-white ${statusColor}`}></span>
			</span>
		</div>

		<div class="flex items-center gap-1 flex-wrap">
			<span class="font-semibold text-lg leading-tight">{displayName}</span>
			{badges.length > 0 && (
				<div class="flex items-center gap-0.5">
					{badges.map((badge) => (
						<img
							src={`https://cdn.discordapp.com/badge-icons/${badge.icon}.png`}
							alt={badge.description}
							title={badge.description}
							class="size-[18px]"
							draggable="false"
						/>
					))}
				</div>
			)}
		</div>

		<p class="text-neutral-600 text-sm">@{username}</p>
	</div>
</a>
