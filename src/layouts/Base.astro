---
import { Font } from "astro:assets";
import "../styles/global.css";
import Background from "../components/Background.astro";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Crspy — fullstack web developer",
  description = "Crspy is a fullstack web developer based in California. CS/CE student writing TypeScript, Go, and Rust.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    <title>{title}</title>

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://crspy.me" />

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-jetbrains" preload />

    <noscript>
      <style>
        [data-rise] { clip-path: none !important; }
        [data-section-marker] [data-marker-line] { transform: scaleX(1) !important; }
      </style>
    </noscript>
  </head>
  <body>
    <Background />
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  main {
    position: relative;
    z-index: 1;
  }
</style>

<script>
  import { initSectionMarkers } from "../scripts/section-markers";
  import { initReveal } from "../scripts/reveal";
  import { initScramble } from "../scripts/scramble";
  import { initProjectHover } from "../scripts/project-hover";

  function init() {
    initSectionMarkers();
    initReveal();
    initScramble();
    initProjectHover();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
