---
<section data-page="/projects" class="min-h-screen">
	<SectionBar title="Projects" class="bg-amber-300" />
	<div class="flex flex-col gap-16 px-8 md:px-16 py-16 max-w-7xl mx-auto">
		{projects.map(p => <ProjectCard {...p} />)}
	</div>
</section>
