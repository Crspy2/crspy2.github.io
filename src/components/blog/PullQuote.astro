---
interface Props {
  /** Optional citation URL (sets the cite attribute on the blockquote). */
  cite?: string;
  /** Optional attribution shown below the quote (e.g. "— Author Name"). */
  attribution?: string;
}

const { cite, attribution } = Astro.props;
---
<blockquote class="pullquote" {...(cite ? { cite } : {})}>
  <div class="pullquote-mark" aria-hidden="true">&ldquo;</div>
  <div class="pullquote-text"><slot /></div>
  {attribution && <footer class="pullquote-attribution">{attribution}</footer>}
</blockquote>

<style>
  .pullquote {
    margin: 2em 0;
    padding: 8px 0 8px 28px;
    border-left: 3px solid var(--color-accent);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.4;
    color: var(--color-foreground);
    max-width: 92%;
    position: relative;
  }

  .pullquote-mark {
    position: absolute;
    top: -8px;
    left: 16px;
    font-family: var(--font-display);
    font-size: 64px;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.3;
    pointer-events: none;
  }

  .pullquote-text :global(p) {
    margin: 0;
  }
  .pullquote-text :global(p + p) {
    margin-top: 0.4em;
  }

  .pullquote-attribution {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-dim);
  }
</style>
