---
interface Props {
  index: string;
  title: string;
  rightSlot?: string;
}

const { index, title, rightSlot } = Astro.props;
---
<div class="section-marker" data-section-marker data-rise>
  <span class="marker-label">// {index} — {title}</span>
  <span class="marker-line" data-marker-line></span>
  {rightSlot && <span class="marker-right">{rightSlot}</span>}
</div>

<style>
  .section-marker {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0 auto;
    padding: 0 32px;
    max-width: 1100px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .section-marker { padding: 0 20px; gap: 12px; }
  }

  .marker-label {
    flex-shrink: 0;
  }

  .marker-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
    transform-origin: left center;
  }

  .marker-right {
    flex-shrink: 0;
    opacity: 0.6;
  }
</style>
