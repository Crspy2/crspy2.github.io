---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** The image source. Pass an imported asset for full optimization. */
  src: ImageMetadata;
  /** Required alt text. */
  alt: string;
  /** Override the default responsive widths if needed. */
  widths?: number[];
  /** Override the default sizes attribute. */
  sizes?: string;
}

const {
  src,
  alt,
  widths = [480, 720, 1080, 1440],
  sizes = '(max-width: 880px) 100vw, 880px',
} = Astro.props;
---
<figure class="post-figure">
  <Image src={src} alt={alt} widths={widths} sizes={sizes} loading="lazy" />
  <figcaption><slot /></figcaption>
</figure>

<style>
  /* Inherits .post-body figure / figcaption / figure img styles from global.css.
     The class is added for any future scoped overrides. */
  .post-figure {
    margin: 1.5em 0 0;
  }
</style>
