---
import { Icon } from "astro-iconify";
import { tools } from "../data/tools";

interface Props {
	name: string;
}

const { name } = Astro.props;
const tool = tools[name];
const icon = tool?.icon;
const href = tool?.href;
const Tag = href ? "a" : "span";
const IconComp = icon && typeof icon !== "string" ? icon : null;
---
<Tag
	href={href}
	target={href ? "_blank" : undefined}
	rel={href ? "noopener noreferrer" : undefined}
	class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-neutral-200 hover:border-neutral-400 hover:bg-neutral-50 transition-colors text-sm select-none"
>
	{(IconComp || typeof icon === "string") && (
		<span class="inline-flex items-center justify-center w-4 h-4 shrink-0">
			{IconComp
				? <IconComp class="w-full h-full" />
				: <Icon name={icon} class="w-full h-full" />
			}
		</span>
	)}
	<span>{name}</span>
</Tag>
